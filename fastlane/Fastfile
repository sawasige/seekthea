default_platform(:ios)

platform :ios do
  desc "メタデータとスクリーンショットをアップロード（バージョン未作成なら作成）"
  lane :upload_metadata do
    setup_api_key
    deliver(
      app_version: current_app_version,
      skip_binary_upload: true,
      skip_screenshots: false,
      overwrite_screenshots: true,
      force: true,
      run_precheck_before_submit: false,
      submit_for_review: false,
      automatic_release: false
    )
  end

  desc "メタデータのみアップロード（バージョン未作成なら作成）"
  lane :upload_metadata_only do
    setup_api_key
    deliver(
      app_version: current_app_version,
      skip_binary_upload: true,
      skip_screenshots: true,
      force: true,
      run_precheck_before_submit: false,
      submit_for_review: false,
      automatic_release: false
    )
  end

  desc "スクリーンショットのみアップロード（既存バージョンへ）"
  lane :upload_screenshots do
    setup_api_key
    deliver(
      skip_binary_upload: true,
      skip_metadata: true,
      skip_app_version_update: true,
      overwrite_screenshots: true,
      force: true,
      run_precheck_before_submit: false
    )
  end

  desc "メタデータをダウンロード"
  lane :download_metadata do
    setup_api_key
    sh("bundle exec fastlane deliver download_metadata")
    sh("bundle exec fastlane deliver download_screenshots")
  end
end

platform :mac do
  desc "macOSメタデータをアップロード（バージョン未作成なら作成）"
  lane :upload_metadata_only do
    setup_api_key
    deliver(
      app_version: current_app_version,
      skip_binary_upload: true,
      skip_screenshots: true,
      force: true,
      platform: "osx",
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false,
      submit_for_review: false,
      automatic_release: false
    )
  end

  desc "macOSスクリーンショットをアップロード（既存バージョンへ）"
  lane :upload_screenshots do
    setup_api_key
    deliver(
      skip_binary_upload: true,
      skip_metadata: true,
      skip_app_version_update: true,
      screenshots_path: "./fastlane/screenshots-mac",
      overwrite_screenshots: true,
      force: true,
      platform: "osx",
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false
    )
  end
end

platform :visionos do
  desc "visionOSメタデータをアップロード（バージョン未作成なら作成）"
  lane :upload_metadata_only do
    setup_api_key
    deliver(
      app_version: current_app_version,
      skip_binary_upload: true,
      skip_screenshots: true,
      force: true,
      platform: "xros",
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false,
      submit_for_review: false,
      automatic_release: false
    )
  end

  desc "visionOSスクリーンショットをアップロード（既存バージョンへ）"
  lane :upload_screenshots do
    setup_api_key
    deliver(
      skip_binary_upload: true,
      skip_metadata: true,
      skip_app_version_update: true,
      screenshots_path: "./fastlane/screenshots-visionos",
      overwrite_screenshots: true,
      force: true,
      platform: "xros",
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false
    )
  end
end

def setup_api_key
  if ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"]
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_KEY"]
    )
  elsif File.exist?("api_key.json")
    api_key_json = JSON.parse(File.read("api_key.json"))
    app_store_connect_api_key(
      key_id: api_key_json["key_id"],
      issuer_id: api_key_json["issuer_id"],
      key_content: api_key_json["key"]
    )
  else
    UI.user_error!("API key not found. Create fastlane/api_key.json from api_key.json.template")
  end
end

# Xcode project から現在の MARKETING_VERSION を取得する。
# 全ターゲット（iOS / macOS / visionOS）で同じ値を共有しているので Seekthea ターゲットで読む。
def current_app_version
  get_version_number(
    xcodeproj: "Seekthea/Seekthea.xcodeproj",
    target: "Seekthea"
  )
end
